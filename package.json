{
  "name": "pomerium-desktop",
  "version": "0.32.2",
  "productName": "PomeriumDesktop",
  "description": "Cross Platform Desktop Application for establishing TCP connections through Pomerium",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "concurrently \"npm run download\" \"npm run metadata\" && electron-vite build",
    "preview": "electron-vite preview",
    "download": "npx tsx scripts/DownloadBinaries.ts",
    "dev-setup": "git clone https://github.com/pomerium/cli && ln -s $(pwd)/cli/bin/pomerium-cli assets/bin/ && cd cli && make build && npm run metadata",
    "build-cli": "cd cli && git pull origin; make build",
    "metadata": "npx tsx scripts/WriteMetadata.ts",
    "lint": "cross-env NODE_ENV=development eslint . --cache --ext .js,.jsx,.ts,.tsx",
    "package": "npm run build && electron-builder build --publish never",
    "release": "npm run build && electron-builder build --publish always",
    "postinstall": "electron-builder install-app-deps",
    "test": "vitest run --passWithNoTests",
    "protoc": "scripts/protoc --ts_proto_out=./src/shared/pb/ --ts_proto_opt=outputServices=grpc-js,esModuleInterop=true --proto_path=. api.proto && prettier --write ./src/shared/pb"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "cross-env NODE_ENV=development eslint --cache"
    ],
    "{*.json,.{eslintrc,prettierrc}}": [
      "prettier --ignore-path .eslintignore --parser json --write"
    ],
    "*.{css,scss}": [
      "prettier --ignore-path .eslintignore --single-quote --write"
    ],
    "*.{html,md,yml}": [
      "prettier --ignore-path .eslintignore --single-quote --write"
    ]
  },
  "build": {
    "productName": "Pomerium Desktop",
    "appId": "io.pomerium.PomeriumDesktop",
    "directories": {
      "buildResources": "assets",
      "output": "release"
    },
    "files": [
      "out/**/*",
      "!out/**/*.map"
    ],
    "afterSign": "scripts/Notarize.js",
    "mac": {
      "target": [
        "dmg"
      ],
      "type": "distribution",
      "hardenedRuntime": true,
      "entitlements": "system_files/mac/common/entitlements.mac.plist",
      "entitlementsInherit": "system_files/mac/common/entitlements.mac.plist",
      "gatekeeperAssess": false,
      "notarize": false
    },
    "dmg": {
      "sign": false,
      "contents": [
        {
          "x": 130,
          "y": 220
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ]
    },
    "win": {
      "target": [
        "nsis"
      ]
    },
    "linux": {
      "target": [
        "AppImage"
      ],
      "category": "Zero-Trust"
    },
    "extraResources": [
      {
        "from": "system_files/${os}/common",
        "to": "assets/"
      },
      {
        "from": "system_files/${os}/${arch}",
        "to": "assets/"
      },
      "./assets/**"
    ],
    "publish": {
      "provider": "github",
      "owner": "pomerium",
      "repo": "desktop-client"
    }
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pomerium/desktop-client.git"
  },
  "author": {
    "name": "Pomerium Inc",
    "email": "info@pomerium.com",
    "url": "https://pomerium.io/"
  },
  "contributors": [
    {
      "name": "Nathan Hayfield",
      "email": "nhayfield@pomerium.com",
      "url": "https://github.com/nhayfield"
    }
  ],
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/pomerium/desktop-client/issues"
  },
  "keywords": [
    "zero trust",
    "network",
    "internal",
    "security"
  ],
  "homepage": "https://github.com/pomerium/desktop-client#readme",
  "devDependencies": {
    "@electron/notarize": "^2.5.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^14.1.2",
    "@trivago/prettier-plugin-sort-imports": "^5.2.2",
    "@types/history": "5.0.0",
    "@types/node": "20.11.5",
    "@types/react": "^18.2.79",
    "@types/react-dom": "^18.2.25",
    "@types/react-router": "5.1.20",
    "@typescript-eslint/eslint-plugin": "^6.19.0",
    "@typescript-eslint/parser": "^6.19.0",
    "@vitejs/plugin-react": "^6.0.1",
    "axios": "^1.15.0",
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "electron": "39.8.5",
    "electron-builder": "^26.5.0",
    "electron-vite": "^5.0.0",
    "eslint": "^8.56.0",
    "eslint-config-airbnb": "^19.0.4",
    "eslint-config-airbnb-typescript": "^17.1.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-compat": "^4.2.0",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-jsx-a11y": "6.10.2",
    "eslint-plugin-prettier": "^5.2.3",
    "eslint-plugin-promise": "^6.1.1",
    "eslint-plugin-react": "^7.37.4",
    "eslint-plugin-react-hooks": "^4.2.0",
    "gunzip-stream": "^1.0.1",
    "husky": "^7.0.1",
    "jsdom": "^29.0.1",
    "lint-staged": "^15.4.3",
    "prettier": "^3.5.0",
    "tar-stream": "^3.1.7",
    "tsx": "^4.20.6",
    "typescript": "^5.3.3",
    "unzip-stream": "^0.3.2",
    "vite": "^8.0.5",
    "vitest": "^4.1.2"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.0",
    "@fontsource/dm-sans": "^5.1.1",
    "@grpc/grpc-js": "^1.12.6",
    "@mui/icons-material": "^6.4.4",
    "@mui/lab": "^5.0.0-alpha.161",
    "@mui/material": "^5.15.5",
    "@mui/styles": "^5.15.5",
    "@sentry/electron": "^5.12.0",
    "electron-context-menu": "^3.6.1",
    "electron-debug": "^3.1.0",
    "electron-is-packaged": "^1.0.2",
    "electron-log": "^5.0.3",
    "electron-store": "^8.1.0",
    "electron-updater": "^6.3.9",
    "history": "^5.0.0",
    "json-schema": "^0.4.0",
    "menubar": "^9.4.0",
    "moment": "^2.30.1",
    "notistack": "^3.0.2",
    "nth-check": "2.1.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-feather": "^2.0.9",
    "react-router": "6.30.3",
    "react-router-dom": "6.30.3",
    "ts-proto": "^1.166.2",
    "typescript-eslint": "^0.0.1-alpha.0",
    "usehooks-ts": "^3.1.1",
    "validator": "^13.15.22"
  },
  "overrides": {
    "tar": "^7.5.11",
    "flatted": ">=3.4.2",
    "picomatch": ">=2.3.2",
    "yaml": ">=2.8.3",
    "ajv-formats": {
      "ajv": ">=8.18.0"
    },
    "conf": {
      "ajv": ">=8.18.0"
    },
    "@typescript-eslint/typescript-estree": {
      "minimatch": ">=9.0.7"
    }
  },
  "packageManager": "npm@11.11.0",
  "engines": {
    "node": ">=20",
    "npm": ">=10",
    "yarn": "YARN NO LONGER USED - use npm instead."
  },
  "browserslist": [],
  "prettier": {
    "overrides": [
      {
        "files": [
          ".prettierrc",
          ".eslintrc"
        ],
        "options": {
          "parser": "json"
        }
      }
    ],
    "singleQuote": true,
    "plugins": [
      "@trivago/prettier-plugin-sort-imports"
    ],
    "importOrder": [
      "^[./]"
    ],
    "importOrderSeparation": true
  },
  "renovate": {
    "extends": [
      "bliss"
    ],
    "baseBranches": [
      "next"
    ]
  },
  "husky": {
    "hooks": {
      "pre-commit": "lint-staged"
    }
  },
  "pomeriumCli": {
    "version": "v0.32.2"
  }
}
